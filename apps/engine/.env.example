# apps/engine — Python engine / QA service + background job consumers
# Copy to .env and fill real values. NEVER commit .env or any secret.
#
# Only environment-specific values (connections, secrets, endpoints, model ids) and per-deploy
# feature toggles live here. Standard tuning defaults (retrieval weights, top-k, timeouts,
# worker timings, context-window sizing, sync limits) live in src/config/constants.py and are
# still env-overridable if you ever need to. See .cursor/rules/engine-config.mdc.

# --- Database ---
# URL-encode special characters in passwords (@ → %40, # → %23, etc.)
DATABASE_URL=postgresql://codesage_dba:change-me@localhost:5432/codesage_db

# --- Service ---
ENGINE_PORT=8001                       # Docker host port mapping (Compose only; not read by app yet)

# --- Worker ---
REPO_CLONE_DIR=/var/codesage/repos     # where sync jobs clone repositories
TOKEN_ENC_KEY=                         # base64 32-byte AES key (must match apps/api)
WORKER_STALE_JOB_SECONDS=600           # stale running reclaim (engine) + re-index throttle (API); must match root .env
LOG_LEVEL=info                         # indexing log verbosity (info or debug for per-file detail)

# --- LLM inference ---
# Both clients speak the OpenAI API, so any OpenAI-compatible server works.
#
# Local: Ollama. Pull a chat model first (llama3.2:1b is lightest; qwen2.5:7b is a stronger
# step-up if you have the RAM/VRAM):
#   ollama pull qwen2.5:7b
# In Docker, replace localhost with host.docker.internal so the container reaches your host.
VLLM_BASE_URL=http://localhost:11434/v1
VLLM_MODEL=qwen2.5:7b
# Production alternative (Machine 2, GPU) — vLLM:
# VLLM_BASE_URL=http://127.0.0.1:8000/v1
# VLLM_MODEL=meta-llama/Llama-3.2-3B-Instruct

# --- Embeddings ---
# EMBEDDING_DIMENSION is the fixed pgvector column width; the embedding model MUST
# output exactly this many dimensions. Changing it requires a DB migration.
EMBEDDING_DIMENSION=1024
#
# Local, low-spec (default): Ollama with a 1024-dim model (matches EMBEDDING_DIMENSION).
#   ollama pull mxbai-embed-large
TEI_BASE_URL=http://localhost:11434/v1
TEI_EMBED_MODEL=mxbai-embed-large
# Production alternative — Text Embeddings Inference (TEI), also 1024-dim:
# TEI_BASE_URL=http://127.0.0.1:8080
# TEI_EMBED_MODEL=BAAI/bge-large-en-v1.5

# --- Feature toggles (per-deploy) ---
# Enable/disable capabilities without editing Python. Tuning knobs for each feature are
# constants in src/config/constants.py.
LLM_CONTEXT_DETECT_ENABLED=true        # auto-detect model context window (vLLM max_model_len / Ollama /api/show)
RETRIEVAL_GRAPH_ENABLED=true           # expand QA retrieval along graph edges
FRESHNESS_POLL_ENABLED=true            # background git ls-remote poll when webhooks miss pushes

# --- Reranker (M3.3, optional cross-encoder via TEI /rerank) ---
# Enable flag + endpoint are env-specific; model id and candidate limits are constants.
RETRIEVAL_RERANKER_ENABLED=false
RETRIEVAL_RERANKER_BASE_URL=           # e.g. http://localhost:8081 (empty = disabled path)
RETRIEVAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
