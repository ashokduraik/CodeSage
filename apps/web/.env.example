# apps/web — React frontend (Vite)
# Copy to .env and fill real values. NEVER commit .env or any secret.
# VITE_* variables are inlined into the browser bundle at build time.

# Base URL the frontend uses to reach the Node API.
# In dev the Vite proxy rewrites /api → http://localhost:3000 (see vite.config.ts).
# Override for standalone builds or non-default API ports.
VITE_API_BASE_URL=/api
