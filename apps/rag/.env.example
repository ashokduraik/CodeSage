# apps/rag — Python RAG / QA service + background job consumers
# Copy to .env and fill real values. NEVER commit .env or any secret.

# --- Database ---
# URL-encode special characters in passwords (@ → %40, # → %23, etc.)
DATABASE_URL=postgresql://codesage_dba:change-me@localhost:5432/codesage_db

# --- Service ---
RAG_PORT=8001

# --- Worker ---
WORKER_POLL_SECONDS=2
WORKER_IDLE_SECONDS=10
WORKER_STALE_JOB_SECONDS=600           # stale running reclaim (RAG) + re-index throttle (API); must match root .env
WORKER_MAX_JOB_ATTEMPTS=3
LOG_LEVEL=info
REPO_CLONE_DIR=/var/codesage/repos
TOKEN_ENC_KEY=                         # base64 32-byte AES key (must match apps/api)

# --- LLM inference ---
# Both clients speak the OpenAI API, so any OpenAI-compatible server works.
#
# Local: Ollama. Pull a chat model first (llama3.2:1b is lightest; qwen2.5:7b is a stronger
# step-up if you have the RAM/VRAM):
#   ollama pull qwen2.5:7b
# In Docker, replace localhost with host.docker.internal so the container reaches your host.
VLLM_BASE_URL=http://localhost:11434/v1
VLLM_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=300                 # raise for slow local CPU inference / cold model loads
# Production alternative (Machine 2, GPU) — vLLM:
# VLLM_BASE_URL=http://127.0.0.1:8000/v1
# VLLM_MODEL=meta-llama/Llama-3.2-3B-Instruct

# --- Embeddings ---
# EMBEDDING_DIMENSION is the fixed pgvector column width; the embedding model MUST
# output exactly this many dimensions. Changing it requires a DB migration.
EMBEDDING_DIMENSION=1024
#
# Local, low-spec (default): Ollama with a 1024-dim model (matches EMBEDDING_DIMENSION).
#   ollama pull mxbai-embed-large
TEI_BASE_URL=http://localhost:11434/v1
TEI_EMBED_MODEL=mxbai-embed-large
EMBEDDING_TIMEOUT_SECONDS=300           # raise for slow local CPU embedding / cold model loads

# --- Startup backend check ---
STARTUP_PROBE_TIMEOUT_SECONDS=5        # per-backend reachability probe at boot (non-fatal; warns only)
# Production alternative — Text Embeddings Inference (TEI), also 1024-dim:
# TEI_BASE_URL=http://127.0.0.1:8080
# TEI_EMBED_MODEL=BAAI/bge-large-en-v1.5

# --- Context window (grounded QA) ---
# The LLM prompt is packed to fill the connected model's context. The window is auto-
# detected (vLLM max_model_len / Ollama /api/show); LLM_MAX_CONTEXT_TOKENS is the
# fallback when detection is disabled or fails. LLM_COMPLETION_RESERVE_TOKENS is held
# back for the generated answer (also sent as max_tokens).
LLM_CONTEXT_DETECT_ENABLED=true
LLM_MAX_CONTEXT_TOKENS=8192
LLM_COMPLETION_RESERVE_TOKENS=1024

# --- Retrieval (developer QA) ---
RETRIEVAL_TOP_K=20                     # candidates retrieved; the packer fills the context window from these
RETRIEVAL_MAX_DISTANCE=0.45
RETRIEVAL_GRAPH_ENABLED=true
RETRIEVAL_GRAPH_MAX_DEPTH=2
RETRIEVAL_GRAPH_MAX_EXTRA_CHUNKS=4

# --- Freshness (Phase 3) ---
FRESHNESS_POLL_ENABLED=true
FRESHNESS_POLL_INTERVAL_SECONDS=900    # 15 min fallback when webhooks miss pushes
