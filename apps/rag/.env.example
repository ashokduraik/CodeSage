# apps/rag — Python RAG / QA service + background job consumers
# Copy to .env and fill real values. NEVER commit .env or any secret.

# --- Database ---
DATABASE_URL=postgresql://codesage:change-me@localhost:5432/codesage

# --- Service ---
RAG_PORT=8001

# --- Worker ---
WORKER_CONCURRENCY=2                   # max parallel heavy jobs; keep low so interactive QA stays responsive
REPO_CLONE_DIR=/var/codesage/repos     # where `sync` clones repositories

# --- LLM inference (Machine 2, GPU) ---
VLLM_BASE_URL=http://vllm:8000/v1      # OpenAI-compatible vLLM endpoint
VLLM_MODEL=                            # open-weight model id (set in Phase 1)

# --- Embeddings ---
TEI_BASE_URL=http://tei:8080           # Text Embeddings Inference endpoint
TEI_EMBED_MODEL=                       # JS/TS-capable code embedding model (set in Phase 1)
