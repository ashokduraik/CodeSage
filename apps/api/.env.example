# apps/api — Node API service
# Copy to .env and fill real values. NEVER commit .env or any secret.

# --- Server ---
API_HOST=0.0.0.0
API_PORT=3000
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://codesage:change-me@localhost:5432/codesage

# --- Auth ---
JWT_SECRET=change-me                   # secret — JWT signing key
AUTH_TOKEN_TTL=1h                      # token lifetime — use time-span strings: "1h", "30m", "3600s"

# --- Token encryption (repo tokens encrypted at rest, ADR 0011/0013) ---
TOKEN_ENC_KEY=change-me                # secret — base64-encoded 32-byte AES-256 key

# --- Mock mode ---
MOCK_MODE=false                        # set to "true" to serve static mock data instead of querying the DB
