# apps/api — Node API service
# Copy to .env and fill real values. NEVER commit .env or any secret.

# --- Server ---
API_HOST=0.0.0.0
API_PORT=3000
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://codesage:change-me@localhost:5432/codesage

# --- Auth ---
JWT_SECRET=change-me                   # secret — JWT signing key
AUTH_TOKEN_TTL=1h                      # token lifetime — use time-span strings: "1h", "30m", "3600s"

# --- Token encryption (repo tokens encrypted at rest, ADR 0011/0013) ---
# Must be base64 of exactly 32 random bytes — NOT a plain-text password.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=change-me                       # secret — paste generated base64 key here

# --- Webhooks (push events → auto re-index) ---
WEBHOOK_BASE_URL=https://codesage.example.com   # public URL of this instance; required for webhook registration

# --- Internal services ---
RAG_BASE_URL=http://127.0.0.1:8001
MOCK_MODE=false                        # set to "true" to serve static mock data instead of querying the DB
