# E2E Playwright — copy to .env in this directory (never commit .env).
# Prerequisites: PostgreSQL up, API + web (`npm run dev`), RAG (`npm run dev:engine`).
# Agent QA chat journey also needs a tool-calling LLM (see apps/engine/README.md).

# Stack
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:3000/api
# Optional — engine health / plannerTools probe (default matches apps/api ENGINE_BASE_URL)
# E2E_ENGINE_URL=http://127.0.0.1:8001

# Dev login (matches API seed)
E2E_DEV_EMAIL=dev@codesage.dev
E2E_DEV_PASSWORD=dev123

# Required — private repo attach tests (typed into Attach Repo in the UI)
E2E_PRIVATE_REPO_URL=
E2E_GITHUB_TOKEN=

# Optional — public repo default is octocat/Hello-World in code.
# Journey #2 (developer chat) needs indexable .ts/.js/.tsx/.jsx — override when the
# default repo has no source files (Hello-World is README-only).
# E2E_PUBLIC_REPO_URL=https://github.com/octocat/Hello-World.git
# E2E_REPO_BRANCH=main
# E2E_HEADLESS=1
# E2E_SKIP=1
# When 1, global-setup fails if engine /health reports plannerTools != ok
# E2E_AGENT_QA_REQUIRED=0
