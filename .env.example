# CodeSage — example environment configuration.
# Copy to `.env` and fill real values. NEVER commit a real .env or any secret.
# This file documents every variable; keep it in sync as variables are added.
# Status: placeholder — variable set is finalized during Phase 0.

# --- Database (Machine 1) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=codesage
POSTGRES_USER=codesage
POSTGRES_PASSWORD=change-me            # secret — do not commit real value
DATABASE_URL=postgresql://codesage:change-me@localhost:5432/codesage

# --- Auth (apps/api) ---
JWT_SECRET=change-me                   # secret — Auth.js / JWT signing key
AUTH_TOKEN_TTL=3600

# --- Token encryption (repo tokens encrypted at rest, ADR 0011/0013) ---
TOKEN_ENC_KEY=change-me                # secret — envelope encryption key (base64)

# --- Inference (Machine 2, GPU) ---
VLLM_BASE_URL=http://vllm:8000/v1      # OpenAI-compatible vLLM endpoint
VLLM_MODEL=                            # TODO(Phase 1): chosen open-weight model id
TEI_BASE_URL=http://tei:8080           # embeddings endpoint
TEI_EMBED_MODEL=                       # TODO(Phase 1): JS/TS-capable code embedding model
EMBEDDING_DIMENSION=1024               # pgvector halfvec column width (must match TEI model)

# --- Services ---
API_PORT=3000
RAG_PORT=8001
WORKER_CONCURRENCY=2                   # cap heavy jobs so interactive QA stays responsive

# --- Repos / filesystem ---
REPO_CLONE_DIR=/var/codesage/repos     # where worker `sync` clones repositories
