# CodeSage — example environment configuration.
# Copy to `.env` and fill real values. NEVER commit a real `.env` or any secret.
# Phase 1 adds TEI/vLLM variables; use `docker compose -f docker-compose.yml -f docker-compose.gpu.yml --profile gpu up` for GPU services.

# --- Database (Machine 1) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=codesage
POSTGRES_USER=codesage
POSTGRES_PASSWORD=change-me            # secret — do not commit real value
DATABASE_URL=postgresql://codesage:change-me@localhost:5432/codesage

# --- Auth (apps/api) ---
JWT_SECRET=change-me                   # secret — Auth.js / JWT signing key
AUTH_TOKEN_TTL=10h

# --- Token encryption (repo tokens encrypted at rest, ADR 0011/0013) ---
TOKEN_ENC_KEY=change-me                # secret — envelope encryption key (base64)

# --- Inference ---
# Both clients speak the OpenAI API, so any OpenAI-compatible server works.
# Local, low-spec default: Ollama (http://localhost:11434/v1). In Compose use
# http://host.docker.internal:11434/v1 so containers can reach the host. Omit VLLM_* to
# use excerpt-based fallback answers. Pull models first:
#   ollama pull qwen2.5:7b && ollama pull mxbai-embed-large
VLLM_BASE_URL=http://localhost:11434/v1    # OpenAI-compatible endpoint (Ollama local; or vLLM http://vllm:8000/v1)
VLLM_MODEL=qwen2.5:7b                       # local chat model (lighter: llama3.2:1b; prod: Llama-3.2-3B-Instruct on vLLM)
LLM_TIMEOUT_SECONDS=300                     # raise for slow local CPU inference / cold model loads
TEI_BASE_URL=http://localhost:11434/v1     # OpenAI-compatible embeddings (Ollama local; or TEI http://tei:80)
TEI_EMBED_MODEL=mxbai-embed-large          # 1024-dim embeddings (prod: BAAI/bge-large-en-v1.5 on TEI)
EMBEDDING_TIMEOUT_SECONDS=300              # raise for slow local CPU embedding / cold model loads
EMBEDDING_DIMENSION=1024                    # pgvector column width (must match the embedding model)
STARTUP_PROBE_TIMEOUT_SECONDS=5            # per-backend reachability probe at boot (non-fatal; warns only)
HF_TOKEN=                                   # optional — Hugging Face token if the chosen models require it

# --- Services ---
API_PORT=3000
WEBHOOK_BASE_URL=                      # public URL for Git webhook callbacks (tunnel URL in local dev)
RAG_PORT=8001
RAG_BASE_URL=http://127.0.0.1:8001       # Node API -> Python RAG (internal)
WORKER_POLL_SECONDS=2                  # reserved; RAG consumer uses WORKER_IDLE_SECONDS today
WORKER_IDLE_SECONDS=10                 # sleep between polls when the jobs queue is empty
WORKER_STALE_JOB_SECONDS=600           # RAG stale reclaim + API manual re-index throttle (must match in API and RAG)
LOG_LEVEL=info                         # RAG indexing log verbosity (info or debug)
WORKER_CONCURRENCY=2                   # cap heavy jobs so interactive QA stays responsive

# --- Repos / filesystem ---
REPO_CLONE_DIR=/var/codesage/repos     # where worker `sync` clones repositories

# --- Freshness (apps/rag Phase 3) ---
FRESHNESS_POLL_ENABLED=true
FRESHNESS_POLL_INTERVAL_SECONDS=900    # scheduled poll fallback when webhooks miss pushes
