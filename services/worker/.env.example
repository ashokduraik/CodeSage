# services/worker — background job worker (Python / Procrastinate)
# Copy to .env and fill real values. NEVER commit .env or any secret.

# --- Database ---
DATABASE_URL=postgresql://codesage:change-me@localhost:5432/codesage

# --- Worker ---
WORKER_CONCURRENCY=2                   # max parallel heavy jobs; keep low so interactive QA stays responsive

# --- Filesystem ---
REPO_CLONE_DIR=/var/codesage/repos     # where worker `sync` clones repositories
