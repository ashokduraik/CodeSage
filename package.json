{
  "name": "codesage",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted, codebase-aware QA platform (monorepo root).",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Ashok Durai Kannan <ashokduraik@gmail.com>",
  "workspaces": [
    "packages/shared-types",
    "apps/api",
    "apps/web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen.mjs --check",
    "build": "npm run build -w @codesage/shared-types && npm run build -w @codesage/api && npm run build -w @codesage/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "setup": "npm install && npm run sync:python",
    "sync:python": "cd apps/rag && uv sync --dev",
    "test:js": "npm run test --workspaces --if-present",
    "test:python": "cd apps/rag && uv run pytest",
    "test": "npm run test:js && npm run test:python",
    "dev:api": "npm run dev -w @codesage/api",
    "dev:web": "npm run dev -w @codesage/web",
    "dev:rag": "cd apps/rag && uv run uvicorn api.main:app --host 127.0.0.1 --port 8001 --reload"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.3",
    "@rolldown/binding-darwin-x64": "1.0.3",
    "@rolldown/binding-linux-arm64-gnu": "1.0.3",
    "@rolldown/binding-linux-arm64-musl": "1.0.3",
    "@rolldown/binding-linux-x64-gnu": "1.0.3",
    "@rolldown/binding-linux-x64-musl": "1.0.3",
    "@rolldown/binding-win32-arm64-msvc": "1.0.3",
    "@rolldown/binding-win32-x64-msvc": "1.0.3",
    "@rollup/rollup-darwin-arm64": "4.62.0",
    "@rollup/rollup-darwin-x64": "4.62.0",
    "@rollup/rollup-linux-arm64-gnu": "4.62.0",
    "@rollup/rollup-linux-arm64-musl": "4.62.0",
    "@rollup/rollup-linux-x64-gnu": "4.62.0",
    "@rollup/rollup-linux-x64-musl": "4.62.0",
    "@rollup/rollup-win32-arm64-msvc": "4.62.0",
    "@rollup/rollup-win32-x64-msvc": "4.62.0",
    "lightningcss-darwin-arm64": "1.32.0",
    "lightningcss-darwin-x64": "1.32.0",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "lightningcss-linux-arm64-musl": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-linux-x64-musl": "1.32.0",
    "lightningcss-win32-arm64-msvc": "1.32.0",
    "lightningcss-win32-x64-msvc": "1.32.0"
  }
}
